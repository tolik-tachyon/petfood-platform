SERVER_IP=your_server_ip
SERVER_PORT=your_server_port
PG_HOST_PORT=5432
POSTGRES_DB=your_db_name
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=your_rabbitmq_user
RABBITMQ_PASSWORD=your_rabbitmq_password
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
PETS_MINIO_ENDPOINT=your_minio_endpoint
PETS_MINIO_ACCESS_KEY=your_pets_minio_access_key
PETS_MINIO_SECRET_KEY=your_pets_minio_secret_key
PETS_MINIO_BUCKET=your_bucket_name
PETS_MINIO_UPLOAD_TTL_SECONDS=900
PETS_MINIO_DOWNLOAD_TTL_SECONDS=900
ACCOUNT_SERVICE_URL=http://localhost:8080

# Outgoing mail (notifications-service). Same vars work for Gmail or Brevo SMTP relay.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_SSL=false
# Brevo: SMTP login + SMTP key from dashboard; FROM must use your verified sender/domain
SMTP_GMAIL_USER=your_brevo_smtp_login
SMTP_GMAIL_PASS=your_brevo_smtp_key
SMTP_GMAIL_FROM=PetFood <noreply@your-verified-domain.com>
